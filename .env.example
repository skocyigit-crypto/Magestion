# ============================================================================
# Magestion — Configuration Environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================================

# --- Serveur API ---
PORT=8080
NODE_ENV=development
JWT_SECRET=votre-secret-jwt-tres-long-et-aleatoire

# --- Base de donnees PostgreSQL ---
# Optionnel en dev : si absent, bascule automatiquement sur PGlite (Postgres
# embarque, fichier local ./.pglite-data, zero installation). Definissez cette
# variable pour un Postgres reel (Neon, Supabase...) — recommande des que
# plusieurs personnes/appareils doivent partager les memes donnees, ou en prod.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173

# --- Web (Vite, build-time) ---
VITE_API_URL=http://localhost:8080

# --- Stockage fichiers ---
# dev : disque local ; prod : S3-compatible (Cloudflare R2, AWS S3...)
STORAGE_MODE=local
LOCAL_STORAGE_DIR=./storage
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# --- IA (fournisseur choisi : OpenAI) ---
OPENAI_API_KEY=sk-...
# GOOGLE_GEMINI_API_KEY=AIza...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Stripe (facturation SaaS, Phase 5) ---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
